{% extends 'base.html.twig' %}

{% block title %}ASODECO - Accueil{% endblock %}

{% block body %}

<!-- Carrousel principal -->
<div id="heroCarousel" class="carousel slide carousel-fade" data-bs-ride="carousel">
    <div class="carousel-indicators">
        <button type="button" data-bs-target="#heroCarousel" data-bs-slide-to="0" class="active" aria-current="true" aria-label="Slide 1"></button>
        <button type="button" data-bs-target="#heroCarousel" data-bs-slide-to="1" aria-label="Slide 2"></button>
        <button type="button" data-bs-target="#heroCarousel" data-bs-slide-to="2" aria-label="Slide 3"></button>
    </div>
    <div class="carousel-inner">
        <!-- Slide 1 -->
        <div class="carousel-item active">
            <img src="{{ asset('images/reunion rurale.png') }}" class="d-block w-100 h-100" alt="Communauté rurale en RDC">
            <div class="carousel-caption">
                <h1 class="display-4 fw-bold">Ensemble, construisons un avenir durable</h1>
                <p class="lead">ASODECO agit pour la santé, l'éducation, l'environnement et le développement rural en République Démocratique du Congo.</p>
                <a href="{{ path('app_domains') }}" class="btn btn-warning-custom mt-3">Découvrir nos actions <i class="bi bi-arrow-right-short"></i></a>
            </div>
        </div>
        <!-- Slide 2 -->
        <div class="carousel-item">
            <img src="{{ asset('images/infirmier et patient.png') }}" class="d-block w-100 h-100" alt="Santé en RDC">
            <div class="carousel-caption">
                <h1 class="display-4 fw-bold">Santé pour tous</h1>
                <p class="lead">Nous soutenons les centres de santé et menons des campagnes de vaccination dans les zones reculées.</p>
                <a href="{{ path('app_domains') }}" class="btn btn-warning-custom mt-3">Nos actions santé <i class="bi bi-arrow-right-short"></i></a>
            </div>
        </div>
        <!-- Slide 3 -->
        <div class="carousel-item">
            <img src="{{ asset('images/Rural Development.png') }}" class="d-block w-100 h-100" alt="Développement rural en RDC">
            <div class="carousel-caption">
                <h1 class="display-4 fw-bold">Développement rural</h1>
                <p class="lead">Nous construisons des infrastructures, soutenons l'agriculture et renforçons les communautés.</p>
                <a href="{{ path('app_projects') }}" class="btn btn-warning-custom mt-3">Découvrir nos projets <i class="bi bi-arrow-right-short"></i></a>
            </div>
        </div>
    </div>
    <button class="carousel-control-prev" type="button" data-bs-target="#heroCarousel" data-bs-slide="prev">
        <span class="carousel-control-prev-icon" aria-hidden="true"></span>
        <span class="visually-hidden">Précédent</span>
    </button>
    <button class="carousel-control-next" type="button" data-bs-target="#heroCarousel" data-bs-slide="next">
        <span class="carousel-control-next-icon" aria-hidden="true"></span>
        <span class="visually-hidden">Suivant</span>
    </button>
</div>

<!-- Section: Nos domaines d'intervention -->
<section class="py-5">
    <div class="container">
        <div class="text-center mb-5">
            <h2 class="section-title">Nos domaines d'intervention</h2>
            <p class="text-muted">Des actions concrètes pour le développement communautaire</p>
        </div>
        <div class="row g-4">
            {% for domain in domains %}
                <div class="col-md-6 col-lg-4">
                    <div class="card domain-card h-100">
                        {# Affichage de l'image #}
                        {% if domain.imageFilename %}
                            <img src="{{ asset('uploads/domains/' ~ domain.imageFilename) }}" class="card-img-top" alt="{{ domain.name }}">
                        {% else %}
                            <img src="{{ asset('images/default-domain.png') }}" class="card-img-top" alt="{{ domain.name }}">
                        {% endif %}
                        <div class="card-body text-center">
                            {# L'icône a été supprimée car non définie #}
                            <h5 class="card-title">{{ domain.name }}</h5>
                            <p class="card-text">
                                {{ domain.description|striptags|slice(0, 100) }}{% if domain.description|length > 100 %}…{% endif %}
                            </p>
                            <a href="{{ path('app_domain_show', {slug: domain.slug}) }}" class="btn btn-outline-primary btn-sm">En savoir plus</a>
                        </div>
                    </div>
                </div>
            {% else %}
                <!-- Fallback statique si aucun domaine en base -->
                <div class="col-md-6 col-lg-4">
                    <div class="card domain-card h-100">
                        <img src="{{ asset('images/infirmier et patient.png') }}" class="card-img-top" alt="Santé">
                        <div class="card-body text-center">
                            <i class="bi bi-hospital domain-icon"></i>
                            <h5 class="card-title">Santé</h5>
                            <p class="card-text">Accès aux soins, campagnes de vaccination, appui aux centres de santé ruraux.</p>
                        </div>
                    </div>
                </div>
                <div class="col-md-6 col-lg-4">
                    <div class="card domain-card h-100">
                        <img src="https://images.unsplash.com/photo-1503676260728-1c00da094a0b?crop=entropy&cs=tinysrgb&fit=max&w=600&q=80" class="card-img-top" alt="Éducation">
                        <div class="card-body text-center">
                            <i class="bi bi-book domain-icon"></i>
                            <h5 class="card-title">Éducation</h5>
                            <p class="card-text">Construction d'écoles, fournitures scolaires, formation des enseignants.</p>
                        </div>
                    </div>
                </div>
                <div class="col-md-6 col-lg-4">
                    <div class="card domain-card h-100">
                        <img src="https://images.unsplash.com/photo-1542601906990-b4d3fb778b09?crop=entropy&cs=tinysrgb&fit=max&w=600&q=80" class="card-img-top" alt="Environnement">
                        <div class="card-body text-center">
                            <i class="bi bi-tree domain-icon"></i>
                            <h5 class="card-title">Environnement & Climat</h5>
                            <p class="card-text">Restauration des sols, reboisement, sensibilisation au changement climatique.</p>
                        </div>
                    </div>
                </div>
            {% endfor %}
        </div>
        <div class="text-center mt-4">
            <a href="{{ path('app_domains') }}" class="btn btn-outline-secondary">Tous les domaines</a>
        </div>
    </div>
</section>

<!-- Section: Projets en cours (enrichie) -->
<section class="py-5 bg-light">
    <div class="container">
        <div class="text-center mb-5">
            <h2 class="section-title">Projets en cours</h2>
            <p class="text-muted">Découvrez nos actions sur le terrain</p>
        </div>
        <div class="row g-4">
            {% for project in projects %}
                <div class="col-md-6 col-lg-4">
                    <div class="card h-100 shadow-sm">
                        {% if project.imageFilename %}
                            <img src="{{ asset('uploads/projects/' ~ project.imageFilename) }}" class="card-img-top" alt="{{ project.title }}">
                        {% else %}
                            <img src="{{ asset('images/default projet 1.png') }}" class="card-img-top" alt="Projet">
                        {% endif %}
                        <div class="card-body">
                            <h5 class="card-title">{{ project.title }}</h5>
                            <p class="card-text">{{ project.description|striptags|slice(0, 100) }}...</p>
                            <a href="{{ path('app_project_show', {slug: project.slug}) }}" class="btn btn-primary">En savoir plus</a>
                        </div>
                        <div class="card-footer text-muted small">
                            <div>Statut: {{ project.status == 'ongoing' ? 'En cours' : 'Terminé' }}</div>
                            <div class="mt-1">
                                <i class="bi bi-newspaper"></i> {{ project.articleCount }} articles
                                <i class="bi bi-hand-holding-heart ms-2"></i> {{ project.appuiCount }} appuis
                                <i class="bi bi-people ms-2"></i> {{ project.affectationCount }} bénéficiaires
                            </div>
                            {% if project.structureNames is not empty %}
                                <div class="mt-1">
                                    <i class="bi bi-building"></i> {{ project.structureNames|join(', ') }}
                                </div>
                            {% endif %}
                        </div>
                    </div>
                </div>
            {% else %}
                <!-- Fallback statique -->
                <div class="col-md-6 col-lg-4">
                    <div class="card h-100 shadow-sm">
                        <img src="https://images.unsplash.com/photo-1584515933487-779824d29309?crop=entropy&cs=tinysrgb&fit=max&w=600&q=80" class="card-img-top" alt="Projet de santé">
                        <div class="card-body">
                            <h5 class="card-title">Appui aux centres de santé</h5>
                            <p class="card-text">Amélioration de l'accès aux soins dans la région de Kabare...</p>
                            <a href="#" class="btn btn-primary">En savoir plus</a>
                        </div>
                    </div>
                </div>
                <div class="col-md-6 col-lg-4">
                    <div class="card h-100 shadow-sm">
                        <img src="https://images.unsplash.com/photo-1503676260728-1c00da094a0b?crop=entropy&cs=tinysrgb&fit=max&w=600&q=80" class="card-img-top" alt="Projet éducation">
                        <div class="card-body">
                            <h5 class="card-title">Construction d'écoles</h5>
                            <p class="card-text">Construction de 3 écoles primaires dans la province du Sud-Kivu...</p>
                            <a href="#" class="btn btn-primary">En savoir plus</a>
                        </div>
                    </div>
                </div>
                <div class="col-md-6 col-lg-4">
                    <div class="card h-100 shadow-sm">
                        <img src="https://images.unsplash.com/photo-1542601906990-b4d3fb778b09?crop=entropy&cs=tinysrgb&fit=max&w=600&q=80" class="card-img-top" alt="Projet environnement">
                        <div class="card-body">
                            <h5 class="card-title">Reforestation communautaire</h5>
                            <p class="card-text">Plantation de 10 000 arbres pour lutter contre l'érosion...</p>
                            <a href="#" class="btn btn-primary">En savoir plus</a>
                        </div>
                    </div>
                </div>
            {% endfor %}
        </div>
        <div class="text-center mt-4">
            <a href="{{ path('app_projects') }}" class="btn btn-outline-secondary">Voir tous les projets</a>
        </div>
    </div>
</section>

<!-- Section: Dernières actualités -->
<section class="py-5">
    <div class="container">
        <div class="text-center mb-5">
            <h2 class="section-title">Dernières actualités</h2>
            <p class="text-muted">Suivez nos dernières actions sur le terrain</p>
        </div>
        <div class="row g-4">
            {% for article in articles %}
                <div class="col-md-4">
                    <div class="card h-100 shadow-sm">
                        {% if article.imageFilename %}
                            <img src="{{ asset('uploads/articles/' ~ article.imageFilename) }}" class="card-img-top" alt="{{ article.title }}">
                        {% else %}
                            <img src="https://images.unsplash.com/photo-1584515933487-779824d29309?crop=entropy&cs=tinysrgb&fit=max&w=600&q=80" class="card-img-top" alt="Actualité">
                        {% endif %}
                        <div class="card-body">
                            <span class="badge bg-warning text-dark mb-2">Actualité</span>
                            <h5 class="card-title">{{ article.title }}</h5>
                            <p class="card-text">{{ article.content|striptags|slice(0, 100) }}...</p>
                            <a href="{{ path('app_article_show', {slug: article.slug}) }}" class="btn btn-outline-primary btn-sm">Lire la suite</a>
                        </div>
                        <div class="card-footer text-muted small">
                            Publié le {{ article.createdAt|date('d/m/Y') }}
                        </div>
                    </div>
                </div>
            {% else %}
                <!-- Exemples statiques si aucun article -->
                <div class="col-md-4">
                    <div class="card h-100 shadow-sm">
                        <img src="https://images.unsplash.com/photo-1584515933487-779824d29309?crop=entropy&cs=tinysrgb&fit=max&w=600&q=80" class="card-img-top" alt="Distribution de kits alimentaires">
                        <div class="card-body">
                            <span class="badge bg-warning text-dark mb-2">Urgence</span>
                            <h5 class="card-title">Distribution de kits alimentaires</h5>
                            <p class="card-text">Face à l'insécurité alimentaire, ASODECO a distribué 500 kits dans le territoire de Kabare.</p>
                            <a href="#" class="btn btn-outline-primary btn-sm">Lire la suite</a>
                        </div>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="card h-100 shadow-sm">
                        <img src="https://images.unsplash.com/photo-1503676260728-1c00da094a0b?crop=entropy&cs=tinysrgb&fit=max&w=600&q=80" class="card-img-top" alt="Inauguration école">
                        <div class="card-body">
                            <span class="badge bg-success mb-2">Éducation</span>
                            <h5 class="card-title">Inauguration d'une école à Bukavu</h5>
                            <p class="card-text">Une nouvelle école primaire de 6 classes ouvre ses portes grâce à des financements.</p>
                            <a href="#" class="btn btn-outline-primary btn-sm">Lire la suite</a>
                        </div>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="card h-100 shadow-sm">
                        <img src="https://images.unsplash.com/photo-1542601906990-b4d3fb778b09?crop=entropy&cs=tinysrgb&fit=max&w=600&q=80" class="card-img-top" alt="Reforestation">
                        <div class="card-body">
                            <span class="badge bg-info text-dark mb-2">Environnement</span>
                            <h5 class="card-title">Campagne de reboisement</h5>
                            <p class="card-text">10 000 arbres plantés en partenariat avec les communautés locales.</p>
                            <a href="#" class="btn btn-outline-primary btn-sm">Lire la suite</a>
                        </div>
                    </div>
                </div>
            {% endfor %}
        </div>
        <div class="text-center mt-4">
            <a href="{{ path('app_articles') }}" class="btn btn-outline-secondary">Voir toutes les actualités</a>
        </div>
    </div>
</section>

<!-- Section: Chiffres clés -->
<section class="stats-section">
    <div class="container">
        <div class="row text-center g-4">
            <div class="col-md-3 col-6">
                <div class="stat-number">15+</div>
                <p>Projets réalisés</p>
            </div>
            <div class="col-md-3 col-6">
                <div class="stat-number">8</div>
                <p>Provinces couvertes</p>
            </div>
            <div class="col-md-3 col-6">
                <div class="stat-number">10k+</div>
                <p>Bénéficiaires directs</p>
            </div>
            <div class="col-md-3 col-6">
                <div class="stat-number">5</div>
                <p>Partenaires actifs</p>
            </div>
        </div>
    </div>
</section>

<!-- Section: Appel aux donateurs -->
<section class="py-5">
    <div class="container">
        <div class="row align-items-center">
            <div class="col-lg-6 mb-4 mb-lg-0">
                <h2 class="section-title">Soutenez nos actions</h2>
                <p class="lead">Vous êtes bailleur, entreprise ou particulier ? Votre soutien change des vies.</p>
                <p>Nous recherchons des partenaires pour financer nos projets prioritaires : santé maternelle, éducation des filles, résilience climatique, etc.</p>
                <a href="{{ path('app_support') }}" class="btn btn-warning-custom mt-2">Devenir une Structure d'accompagnement</a>
            </div>
            <div class="col-lg-6">
                <img src="{{ asset('images/reunion rurale.png') }}" class="img-fluid rounded shadow" alt="Communauté en RDC">
            </div>
        </div>
    </div>
</section>

{% endblock %}