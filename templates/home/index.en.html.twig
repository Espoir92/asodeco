{% extends 'base.html.twig' %}

{% block title %}ASODECO - Home{% endblock %}

{% block body %}

<!-- Carrousel principal -->
<div id="heroCarousel" class="carousel slide carousel-fade" data-bs-ride="carousel">
    <div class="carousel-indicators">
        <button type="button" data-bs-target="#heroCarousel" data-bs-slide-to="0" class="active" aria-current="true" aria-label="Slide 1"></button>
        <button type="button" data-bs-target="#heroCarousel" data-bs-slide-to="1" aria-label="Slide 2"></button>
        <button type="button" data-bs-target="#heroCarousel" data-bs-slide-to="2" aria-label="Slide 3"></button>
    </div>
    <div class="carousel-inner">
        <!-- Slide 1 -->
        <div class="carousel-item active">
            <img src="{{ asset('images/reunion rurale.png') }}" class="d-block w-100 h-100" alt="Rural community in DRC">
            <div class="carousel-caption">
                <h1 class="display-4 fw-bold">Together, let's build a sustainable future</h1>
                <p class="lead">ASODECO works for health, education, environment and rural development in the Democratic Republic of Congo.</p>
                <a href="{{ path('app_domains_en') }}" class="btn btn-warning-custom mt-3">Discover our actions <i class="bi bi-arrow-right-short"></i></a>
            </div>
        </div>
        <!-- Slide 2 -->
        <div class="carousel-item">
            <img src="{{ asset('images/infirmier et patient.png') }}" class="d-block w-100 h-100" alt="Health in DRC">
            <div class="carousel-caption">
                <h1 class="display-4 fw-bold">Health for all</h1>
                <p class="lead">We support health centers and conduct vaccination campaigns in remote areas.</p>
                <a href="{{ path('app_domains_en') }}" class="btn btn-warning-custom mt-3">Our health actions <i class="bi bi-arrow-right-short"></i></a>
            </div>
        </div>
        <!-- Slide 3 -->
        <div class="carousel-item">
            <img src="{{ asset('images/Rural Development.png') }}" class="d-block w-100 h-100" alt="Rural development in DRC">
            <div class="carousel-caption">
                <h1 class="display-4 fw-bold">Rural development</h1>
                <p class="lead">We build infrastructure, support agriculture and strengthen communities.</p>
                <a href="{{ path('app_domains_en') }}" class="btn btn-warning-custom mt-3">Discover our projects <i class="bi bi-arrow-right-short"></i></a>
            </div>
        </div>
    </div>
    <button class="carousel-control-prev" type="button" data-bs-target="#heroCarousel" data-bs-slide="prev">
        <span class="carousel-control-prev-icon" aria-hidden="true"></span>
        <span class="visually-hidden">Previous</span>
    </button>
    <button class="carousel-control-next" type="button" data-bs-target="#heroCarousel" data-bs-slide="next">
        <span class="carousel-control-next-icon" aria-hidden="true"></span>
        <span class="visually-hidden">Next</span>
    </button>
</div>

<!-- Section: Our areas of intervention -->
<section class="py-5">
    <div class="container">
        <div class="text-center mb-5">
            <h2 class="section-title">Our areas of intervention</h2>
            <p class="text-muted">Concrete actions for community development</p>
        </div>
        <div class="row g-4">
            {% for domain in domains %}
                <div class="col-md-6 col-lg-4">
                    <div class="card domain-card h-100">
                        {% if domain.imageFilename %}
                            <img src="{{ asset('uploads/domains/' ~ domain.imageFilename) }}" class="card-img-top" alt="{{ domain.name }}">
                        {% else %}
                            <img src="{{ asset('images/default-domain.png') }}" class="card-img-top" alt="{{ domain.name }}">
                        {% endif %}
                        <div class="card-body text-center">
                            <h5 class="card-title">{{ domain.nameEn ?? domain.name }}</h5>
                            <p class="card-text">
                                {{ (domain.descriptionEn ?? domain.description)|striptags|slice(0, 100) }}{% if (domain.descriptionEn ?? domain.description)|length > 100 %}…{% endif %}
                            </p>
                            <a href="{{ path('app_domain_show_en', {slug: domain.slug}) }}" class="btn btn-outline-primary btn-sm">Learn more</a>
                        </div>
                    </div>
                </div>
            {% else %}
                <!-- Fallback statique si aucun domaine en base -->
                <div class="col-md-6 col-lg-4">
                    <div class="card domain-card h-100">
                        <img src="{{ asset('images/infirmier et patient.png') }}" class="card-img-top" alt="Health">
                        <div class="card-body text-center">
                            <h5 class="card-title">Health</h5>
                            <p class="card-text">Access to care, vaccination campaigns, support for rural health centers.</p>
                        </div>
                    </div>
                </div>
                <div class="col-md-6 col-lg-4">
                    <div class="card domain-card h-100">
                        <img src="https://images.unsplash.com/photo-1503676260728-1c00da094a0b?crop=entropy&cs=tinysrgb&fit=max&w=600&q=80" class="card-img-top" alt="Education">
                        <div class="card-body text-center">
                            <h5 class="card-title">Education</h5>
                            <p class="card-text">School construction, school supplies, teacher training.</p>
                        </div>
                    </div>
                </div>
                <div class="col-md-6 col-lg-4">
                    <div class="card domain-card h-100">
                        <img src="https://images.unsplash.com/photo-1542601906990-b4d3fb778b09?crop=entropy&cs=tinysrgb&fit=max&w=600&q=80" class="card-img-top" alt="Environment">
                        <div class="card-body text-center">
                            <h5 class="card-title">Environment & Climate</h5>
                            <p class="card-text">Soil restoration, reforestation, climate change awareness.</p>
                        </div>
                    </div>
                </div>
            {% endfor %}
        </div>
        <div class="text-center mt-4">
            <a href="{{ path('app_domains_en') }}" class="btn btn-outline-secondary">All areas</a>
        </div>
    </div>
</section>

<!-- Section: Ongoing projects (enrichie) -->
<section class="py-5 bg-light">
    <div class="container">
        <div class="text-center mb-5">
            <h2 class="section-title">Ongoing projects</h2>
            <p class="text-muted">Discover our actions in the field</p>
        </div>
        <div class="row g-4">
            {% for project in projects %}
                <div class="col-md-6 col-lg-4">
                    <div class="card h-100 shadow-sm">
                        {% if project.imageFilename %}
                            <img src="{{ asset('uploads/projects/' ~ project.imageFilename) }}" class="card-img-top" alt="{{ project.title }}">
                        {% else %}
                            <img src="{{ asset('images/default-project.png') }}" class="card-img-top" alt="Project">
                        {% endif %}
                        <div class="card-body">
                            <h5 class="card-title">{{ project.titleEN ?? project.title }}</h5>
                            <p class="card-text">{{ (project.descriptionEN ?? project.description)|striptags|slice(0, 100) }}...</p>
                            <a href="{{ path('app_project_show_en', {slug: project.slug}) }}" class="btn btn-primary">Learn more</a>
                        </div>
                        <div class="card-footer text-muted small">
                            <div>Status: {{ project.status == 'ongoing' ? 'Ongoing' : 'Completed' }}</div>
                            <div class="mt-1">
                                <i class="bi bi-newspaper"></i> {{ project.articleCount }} articles
                                <i class="bi bi-hand-holding-heart ms-2"></i> {{ project.appuiCount }} supports
                                <i class="bi bi-people ms-2"></i> {{ project.affectationCount }} beneficiaries
                            </div>
                            {% if project.structureNames is not empty %}
                                <div class="mt-1">
                                    <i class="bi bi-building"></i> {{ project.structureNames|join(', ') }}
                                </div>
                            {% endif %}
                        </div>
                    </div>
                </div>
            {% else %}
                <!-- Fallback statique -->
                <div class="col-md-6 col-lg-4">
                    <div class="card h-100 shadow-sm">
                        <img src="https://images.unsplash.com/photo-1584515933487-779824d29309?crop=entropy&cs=tinysrgb&fit=max&w=600&q=80" class="card-img-top" alt="Health project">
                        <div class="card-body">
                            <h5 class="card-title">Support to health centers</h5>
                            <p class="card-text">Improving access to care in the Kabare region...</p>
                            <a href="#" class="btn btn-primary">Learn more</a>
                        </div>
                    </div>
                </div>
                <div class="col-md-6 col-lg-4">
                    <div class="card h-100 shadow-sm">
                        <img src="https://images.unsplash.com/photo-1503676260728-1c00da094a0b?crop=entropy&cs=tinysrgb&fit=max&w=600&q=80" class="card-img-top" alt="Education project">
                        <div class="card-body">
                            <h5 class="card-title">School construction</h5>
                            <p class="card-text">Construction of 3 primary schools in South Kivu...</p>
                            <a href="#" class="btn btn-primary">Learn more</a>
                        </div>
                    </div>
                </div>
                <div class="col-md-6 col-lg-4">
                    <div class="card h-100 shadow-sm">
                        <img src="https://images.unsplash.com/photo-1542601906990-b4d3fb778b09?crop=entropy&cs=tinysrgb&fit=max&w=600&q=80" class="card-img-top" alt="Environment project">
                        <div class="card-body">
                            <h5 class="card-title">Community reforestation</h5>
                            <p class="card-text">Planting 10,000 trees to fight erosion...</p>
                            <a href="#" class="btn btn-primary">Learn more</a>
                        </div>
                    </div>
                </div>
            {% endfor %}
        </div>
        <div class="text-center mt-4">
            <a href="{{ path('app_projects_en') }}" class="btn btn-outline-secondary">See all projects</a>
        </div>
    </div>
</section>

<!-- Section: Latest news -->
<section class="py-5">
    <div class="container">
        <div class="text-center mb-5">
            <h2 class="section-title">Latest news</h2>
            <p class="text-muted">Follow our latest actions in the field</p>
        </div>
        <div class="row g-4">
            {% for article in articles %}
                <div class="col-md-4">
                    <div class="card h-100 shadow-sm">
                        {% if article.imageFilename %}
                            <img src="{{ asset('uploads/articles/' ~ article.imageFilename) }}" class="card-img-top" alt="{{ article.title }}">
                        {% else %}
                            <img src="{{ asset('images/default-article.jpg') }}" class="card-img-top" alt="News">
                        {% endif %}
                        <div class="card-body">
                            <span class="badge bg-warning text-dark mb-2">News</span>
                            <h5 class="card-title">{{ article.titleEn ?? article.title }}</h5>
                            <p class="card-text">{{ (article.contentEn ?? article.content)|striptags|slice(0, 100) }}...</p>
                            <a href="{{ path('app_article_show_en', {slug: article.slug}) }}" class="btn btn-outline-primary btn-sm">Read more</a>
                        </div>
                        <div class="card-footer text-muted small">
                            Published on {{ article.createdAt|date('d/m/Y') }}
                        </div>
                    </div>
                </div>
            {% else %}
                <!-- Fallback statique -->
                <div class="col-md-4">
                    <div class="card h-100 shadow-sm">
                        <img src="https://images.unsplash.com/photo-1584515933487-779824d29309?crop=entropy&cs=tinysrgb&fit=max&w=600&q=80" class="card-img-top" alt="Food distribution">
                        <div class="card-body">
                            <span class="badge bg-warning text-dark mb-2">Emergency</span>
                            <h5 class="card-title">Food kits distribution</h5>
                            <p class="card-text">ASODECO distributed 500 kits in Kabare territory.</p>
                            <a href="#" class="btn btn-outline-primary btn-sm">Read more</a>
                        </div>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="card h-100 shadow-sm">
                        <img src="https://images.unsplash.com/photo-1503676260728-1c00da094a0b?crop=entropy&cs=tinysrgb&fit=max&w=600&q=80" class="card-img-top" alt="School inauguration">
                        <div class="card-body">
                            <span class="badge bg-success mb-2">Education</span>
                            <h5 class="card-title">School inauguration in Bukavu</h5>
                            <p class="card-text">A new primary school with 6 classrooms opens its doors.</p>
                            <a href="#" class="btn btn-outline-primary btn-sm">Read more</a>
                        </div>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="card h-100 shadow-sm">
                        <img src="https://images.unsplash.com/photo-1542601906990-b4d3fb778b09?crop=entropy&cs=tinysrgb&fit=max&w=600&q=80" class="card-img-top" alt="Reforestation">
                        <div class="card-body">
                            <span class="badge bg-info text-dark mb-2">Environment</span>
                            <h5 class="card-title">Reforestation campaign</h5>
                            <p class="card-text">10,000 trees planted with local communities.</p>
                            <a href="#" class="btn btn-outline-primary btn-sm">Read more</a>
                        </div>
                    </div>
                </div>
            {% endfor %}
        </div>
        <div class="text-center mt-4">
            <a href="{{ path('app_articles_en') }}" class="btn btn-outline-secondary">See all news</a>
        </div>
    </div>
</section>

<!-- Section: Key figures -->
<section class="stats-section">
    <div class="container">
        <div class="row text-center g-4">
            <div class="col-md-3 col-6">
                <div class="stat-number">15+</div>
                <p>Projects completed</p>
            </div>
            <div class="col-md-3 col-6">
                <div class="stat-number">8</div>
                <p>Provinces covered</p>
            </div>
            <div class="col-md-3 col-6">
                <div class="stat-number">10k+</div>
                <p>Direct beneficiaries</p>
            </div>
            <div class="col-md-3 col-6">
                <div class="stat-number">5</div>
                <p>Active partners</p>
            </div>
        </div>
    </div>
</section>

<!-- Section: Call to donors -->
<section class="py-5">
    <div class="container">
        <div class="row align-items-center">
            <div class="col-lg-6 mb-4 mb-lg-0">
                <h2 class="section-title">Support our actions</h2>
                <p class="lead">Are you a donor, company or individual? Your support changes lives.</p>
                <p>We are looking for partners to fund our priority projects: maternal health, girls' education, climate resilience, etc.</p>
                <a href="{{ path('app_support_en') }}" class="btn btn-warning-custom mt-2">Become a partner</a>
            </div>
            <div class="col-lg-6">
                <img src="{{ asset('images/reunion rurale.png') }}" class="img-fluid rounded shadow" alt="Community in DRC">
            </div>
        </div>
    </div>
</section>

{% endblock %}