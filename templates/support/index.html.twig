{% extends 'base.html.twig' %}

{% block title %}Devenir partenaire - ASODECO{% endblock %}

{% block body %}
<div class="container py-5">
    <h1 class="mb-4">Devenir une structure d'accompagnement</h1>
    
    <div class="row">
        <div class="col-lg-8">
            <p class="lead">Rejoignez notre réseau de partenaires et contribuez au développement communautaire en RDC.</p>
            
            <h2 class="mt-4">Pourquoi soutenir ASODECO ?</h2>
            <p>Depuis sa création, ASODECO mène des projets concrets dans les domaines de la santé, de l’éducation, de l’environnement et du développement rural. Avec votre soutien, nous pouvons :</p>
            <ul>
                <li>Construire et équiper des écoles et des centres de santé.</li>
                <li>Mettre en place des programmes d’accès à l’eau potable.</li>
                <li>Former des jeunes et des femmes aux métiers porteurs.</li>
                <li>Réhabiliter des infrastructures communautaires.</li>
            </ul>
            
            <h2 class="mt-4">Comment nous soutenir ?</h2>
            <div class="row mt-3">
                <div class="col-md-6 mb-3">
                    <div class="card h-100">
                        <div class="card-body">
                            <h5><i class="bi bi-currency-dollar"></i> Financement</h5>
                            <p>Subvention, don, parrainage de projet. Tous les montants sont les bienvenus.</p>
                        </div>
                    </div>
                </div>
                <div class="col-md-6 mb-3">
                    <div class="card h-100">
                        <div class="card-body">
                            <h5><i class="bi bi-tools"></i> Appui technique</h5>
                            <p>Mise à disposition d’expertise, de matériel, de formations.</p>
                        </div>
                    </div>
                </div>
                <div class="col-md-6 mb-3">
                    <div class="card h-100">
                        <div class="card-body">
                            <h5><i class="bi bi-people"></i> Mise en réseau</h5>
                            <p>Facilitez nos contacts avec des partenaires locaux ou internationaux.</p>
                        </div>
                    </div>
                </div>
                <div class="col-md-6 mb-3">
                    <div class="card h-100">
                        <div class="card-body">
                            <h5><i class="bi bi-briefcase"></i> Volontariat de compétences</h5>
                            <p>Mettez vos compétences au service de nos projets (gestion, communication, etc.).</p>
                        </div>
                    </div>
                </div>
            </div>
            
            <h2 class="mt-4">Documents utiles</h2>
            <ul>
                <li><a href="{{ asset('downloads/Statuts-Asodeco.pdf') }}" target="_blank"><i class="bi bi-file-pdf"></i> Télécharger nos statuts</a></li>
                
                {# Sélecteur d'année pour le rapport d'activité #}
                <li class="mb-2">
                    <div class="d-flex align-items-center gap-2 flex-wrap">
                        <span><i class="bi bi-file-pdf"></i> Rapport d’activité :</span>
                        <form method="get" action="{{ path('app_report_activity') }}" target="_blank" class="d-inline">
                            <select name="year" class="form-select form-select-sm d-inline-block w-auto" required>
                                <option value="" disabled selected>Choisir une année</option>
                                {% for y in range(2020, 'now'|date('Y')) %}
                                    <option value="{{ y }}">{{ y }}</option>
                                {% endfor %}
                            </select>
                            <button type="submit" class="btn btn-sm btn-primary">
                                <i class="bi bi-download"></i> Générer
                            </button>
                        </form>
                    </div>
                </li>
                
                {# <li><a href="{{ asset('downloads/dossier-presentation.pdf') }}" target="_blank"><i class="bi bi-file-pdf"></i> Dossier de présentation</a></li> #}
            {# <li>
    <a href="{{ path(is_english ? 'app_presentation_en' : 'app_presentation') }}" target="_blank">
        <i class="bi bi-file-pdf"></i> 
        {{ is_english ? 'Presentation document' : 'Dossier de présentation' }}
    </a>
</li> #}
{# <li><a href="{{ path('app_presentation') }}" target="_blank"><i class="bi bi-file-pdf"></i> Dossier de présentation</a></li> #}
<li>
    <a href="{{ path('app_presentation_page') }}" target="_blank">
        <i class="bi bi-file-pdf"></i> Dossier de présentation
    </a>
</li>                
</ul>
        </div>
        
        <div class="col-lg-4">
            <div class="card bg-light p-3">
                <h5><i class="bi bi-envelope"></i> Contactez-nous</h5>
                <p>Pour discuter d’un partenariat, écrivez-nous :</p>
                <a href="mailto:partenariat@asodeco.cd" class="btn btn-warning w-100 mb-2">partenariat@asodeco.cd</a>
                <p class="mt-3">Ou remplissez notre formulaire de contact en précisant l’objet "Partenariat".</p>
                <a href="{{ path('app_contact') }}" class="btn btn-outline-primary w-100">Formulaire de contact</a>
            </div>
            
            <div class="card bg-success text-white p-3 mt-4">
                <h5><i class="bi bi-heart"></i> Faites un don</h5>
                <p>Votre contribution financière, même modeste, nous aide à agir.</p>
                <a href="#" class="btn btn-warning w-100">Faire un don</a>
                <small class="mt-2 d-block">Un reçu fiscal vous sera délivré.</small>
            </div>
        </div>
    </div>
</div>
{% endblock %}