{% extends 'base.html.twig' %}

{% block title %}Connexion - ASODECO{% endblock %}

{% block stylesheets %}
    <style>
        body, html {
            overflow-x: hidden;
            margin: 0;
            padding: 0;
            height: 100%;
        }
        .login-section {
            position: relative;
            display: flex;
            align-items: center;
            justify-content: center;
            background: linear-gradient(135deg, rgba(10, 91, 158, 0.85), rgba(13, 110, 253, 0.85));
            padding: 4rem 2rem 2rem 2rem;
            margin-bottom: 0;
            overflow: hidden;
        }
        #bg-canvas {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            display: block;
            z-index: 0;
        }
        .login-overlay {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(0,0,0,0.4);
            z-index: 1;
        }
        .login-card {
            position: relative;
            z-index: 2;
            border: none;
            border-radius: 1rem;
            box-shadow: 0 10px 30px rgba(0,0,0,0.2);
            overflow: hidden;
            backdrop-filter: blur(8px);
            background-color: rgba(255,255,255,0.95);
        }
        .login-card-header {
            background: #0a5b9e;
            color: white;
            text-align: center;
            padding: 1.5rem;
        }
        .login-card-header h4 {
            margin: 0;
            font-weight: 600;
            font-size: 1.8rem;
        }
        .login-card-body {
            padding: 2.5rem;   /* plus d'espace interne */
        }
        .btn-login {
            background-color: #ffc107;
            color: #0a5b9e;
            font-weight: bold;
            padding: 0.75rem;
            border-radius: 2rem;
            transition: all 0.3s;
        }
        .btn-login:hover {
            background-color: #ffcd39;
            transform: translateY(-2px);
            box-shadow: 0 5px 15px rgba(0,0,0,0.1);
        }
        .form-check-input:checked {
            background-color: #0a5b9e;
            border-color: #0a5b9e;
        }
        .error-message {
            background-color: #f8d7da;
            border-left: 4px solid #dc3545;
            padding: 0.75rem 1rem;
            border-radius: 0.5rem;
            margin-bottom: 1rem;
        }
        @media (max-width: 768px) {
            .login-card {
                margin: 1rem;
            }
            .login-section {
                padding: 2rem 1rem;
            }
            .login-card-body {
                padding: 1.5rem;
            }
            .login-card-header h4 {
                font-size: 1.4rem;
            }
        }
    </style>
{% endblock %}

{% block body %}
<section class="login-section">
    <canvas id="bg-canvas"></canvas>
    <div class="login-overlay"></div>
    <div class="container">
        <div class="row justify-content-center">
            <!-- Colonne plus large : 8 colonnes sur tablette, 7 sur desktop -->
            <div class="col-md-8 col-lg-7">
                <div class="card login-card">
                    <div class="login-card-header">
                        <h4><i class="bi bi-shield-lock"></i> Connexion</h4>
                    </div>
                    <div class="login-card-body">
                        {% if error %}
                            <div class="error-message">
                                <i class="bi bi-exclamation-triangle-fill me-2"></i>
                                {{ error.messageKey|trans(error.messageData, 'security') }}
                            </div>
                        {% endif %}

                        <form method="post">
                            <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">

                            <div class="mb-3">
                                <label for="email" class="form-label">Adresse email</label>
                                <div class="input-group">
                                    <span class="input-group-text"><i class="bi bi-envelope"></i></span>
                                    <input type="email" value="{{ last_username }}" name="email" id="email" class="form-control" placeholder="exemple@asodeco.cd" required autofocus>
                                </div>
                            </div>

                            <div class="mb-3">
                                <label for="password" class="form-label">Mot de passe</label>
                                <div class="input-group">
                                    <span class="input-group-text"><i class="bi bi-lock"></i></span>
                                    <input type="password" name="password" id="password" class="form-control" required>
                                </div>
                            </div>

                            <div class="mb-3 form-check">
                                <input type="checkbox" class="form-check-input" id="remember_me" name="_remember_me">
                                <label class="form-check-label" for="remember_me">Se souvenir de moi</label>
                            </div>

                            <button type="submit" class="btn btn-login w-100">
                                <i class="bi bi-box-arrow-in-right"></i> Se connecter
                            </button>
                        </form>

                        <hr class="my-4">

                        <div class="text-center">
                            <small class="text-muted">
                                Vous n'avez pas encore de compte ? <a href="{{ path('app_contact') }}">Contactez-nous</a>
                            </small>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
{% endblock %}

{% block javascripts %}
<script>
    (function() {
        const canvas = document.getElementById('bg-canvas');
        const ctx = canvas.getContext('2d');
        let width = window.innerWidth;
        let height = window.innerHeight;
        let particles = [];
        const particleCount = 150;

        let mouseX = null;
        let mouseY = null;

        function initParticles() {
            particles = [];
            for (let i = 0; i < particleCount; i++) {
                particles.push({
                    x: Math.random() * width,
                    y: Math.random() * height,
                    radius: Math.random() * 2.5 + 0.5,
                    speedX: (Math.random() - 0.5) * 0.3,
                    speedY: (Math.random() - 0.5) * 0.2,
                    alpha: Math.random() * 0.6 + 0.2
                });
            }
        }

        function resizeCanvas() {
            width = window.innerWidth;
            height = window.innerHeight;
            canvas.width = width;
            canvas.height = height;
            initParticles();
        }

        function draw() {
            if (!ctx) return;
            ctx.clearRect(0, 0, width, height);
            ctx.fillStyle = '#0a2f44';
            ctx.fillRect(0, 0, width, height);

            const gradient = ctx.createRadialGradient(width/2, height/2, 0, width/2, height/2, width/2);
            gradient.addColorStop(0, 'rgba(10, 91, 158, 0.3)');
            gradient.addColorStop(1, '#0a2f44');
            ctx.fillStyle = gradient;
            ctx.fillRect(0, 0, width, height);

            particles.forEach(p => {
                ctx.beginPath();
                ctx.arc(p.x, p.y, p.radius, 0, Math.PI * 2);
                ctx.fillStyle = `rgba(255, 255, 255, ${p.alpha})`;
                ctx.fill();
            });

            particles.forEach(p => {
                p.x += p.speedX;
                p.y += p.speedY;

                if (p.x < 0) p.x = width;
                if (p.x > width) p.x = 0;
                if (p.y < 0) p.y = height;
                if (p.y > height) p.y = 0;

                if (mouseX !== null && mouseY !== null) {
                    const dx = p.x - mouseX;
                    const dy = p.y - mouseY;
                    const dist = Math.sqrt(dx * dx + dy * dy);
                    const maxDist = 100;
                    if (dist < maxDist) {
                        const force = (maxDist - dist) / maxDist;
                        const angle = Math.atan2(dy, dx);
                        const moveX = Math.cos(angle) * force * 1.5;
                        const moveY = Math.sin(angle) * force * 1.5;
                        p.x += moveX;
                        p.y += moveY;
                    }
                }
            });

            requestAnimationFrame(draw);
        }

        function onMouseMove(e) {
            mouseX = e.clientX;
            mouseY = e.clientY;
        }

        window.addEventListener('resize', resizeCanvas);
        window.addEventListener('mousemove', onMouseMove);
        resizeCanvas();
        draw();
    })();
</script>
{% endblock %}