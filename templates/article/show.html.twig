{% extends 'base.html.twig' %}

{% block title %}
    {% if is_english is defined and is_english and article.titleEn %}
        {{ article.titleEn }} - ASODECO
    {% else %}
        {{ article.title }} - ASODECO
    {% endif %}
{% endblock %}

{% block body %}
<div class="container py-5">
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb">
            <li class="breadcrumb-item">
                <a href="{{ path(is_english is defined and is_english ? 'app_home_en' : 'app_home') }}">
                    {{ is_english is defined and is_english ? 'Home' : 'Accueil' }}
                </a>
            </li>
            <li class="breadcrumb-item">
                <a href="{{ path(is_english is defined and is_english ? 'app_articles_en' : 'app_articles') }}">
                    {{ is_english is defined and is_english ? 'News' : 'Actualités' }}
                </a>
            </li>
            <li class="breadcrumb-item active">
                {% if is_english is defined and is_english and article.titleEn %}
                    {{ article.titleEn }}
                {% else %}
                    {{ article.title }}
                {% endif %}
            </li>
        </ol>
    </nav>

    <div class="row">
        <div class="col-lg-8">
            <h1 class="mb-3">
                {% if is_english is defined and is_english and article.titleEn %}
                    {{ article.titleEn }}
                {% else %}
                    {{ article.title }}
                {% endif %}
            </h1>
            <div class="text-muted mb-4">
                <i class="bi bi-calendar"></i>
                {% if is_english is defined and is_english %}
                    Published on
                {% else %}
                    Publié le
                {% endif %}
                {{ article.createdAt|date('d/m/Y') }}
                {% if article.updatedAt and article.updatedAt != article.createdAt %}
                    | <i class="bi bi-pencil"></i>
                    {% if is_english is defined and is_english %}
                        Updated on
                    {% else %}
                        Mis à jour le
                    {% endif %}
                    {{ article.updatedAt|date('d/m/Y') }}
                {% endif %}
            </div>

            {% if article.imageFilename %}
                <img src="{{ asset('uploads/articles/' ~ article.imageFilename) }}" class="img-fluid rounded mb-4" alt="{{ article.title }}">
            {% endif %}

            <div class="content">
                {% set content = (is_english is defined and is_english and article.contentEn) ? article.contentEn : article.content %}
                {{ content|raw }}
            </div>

            <a href="{{ path(is_english is defined and is_english ? 'app_articles_en' : 'app_articles') }}"
               class="btn btn-outline-primary mt-4">
                <i class="bi bi-arrow-left"></i>
                {{ is_english is defined and is_english ? 'Back to news' : 'Retour aux actualités' }}
            </a>
        </div>

        <div class="col-lg-4">
            <div class="card bg-light p-3">
                <h5><i class="bi bi-info-circle"></i>
                    {{ is_english is defined and is_english ? 'About' : 'À propos' }}
                </h5>
                <p>
                    {% if is_english is defined and is_english %}
                        Follow all ASODECO news on this page. We regularly publish reports, calls for projects and field news.
                    {% else %}
                        Suivez toutes les actualités d'ASODECO sur cette page. Nous publions régulièrement des rapports, des appels à projets et des nouvelles du terrain.
                    {% endif %}
                </p>
                <hr>
                <h5><i class="bi bi-share"></i>
                    {{ is_english is defined and is_english ? 'Share' : 'Partager' }}
                </h5>
                <div class="d-flex gap-2">
                    <a href="https://www.facebook.com/sharer/sharer.php?u={{ app.request.uri }}" target="_blank" class="btn btn-sm btn-outline-primary"><i class="bi bi-facebook"></i></a>
                    <a href="https://twitter.com/intent/tweet?url={{ app.request.uri }}" target="_blank" class="btn btn-sm btn-outline-primary"><i class="bi bi-twitter-x"></i></a>
                    <a href="https://www.linkedin.com/shareArticle?url={{ app.request.uri }}" target="_blank" class="btn btn-sm btn-outline-primary"><i class="bi bi-linkedin"></i></a>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}